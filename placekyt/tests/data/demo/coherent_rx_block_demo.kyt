project:
  format_version: 1
  name: Coherent BPSK RX
  version: '1.0'
chip_type: kyttar_10x12
chips:
- id: 0
  label: Chip 0
  position: {x: 0.0, y: 0.0}
blocks:
- name: coherentrx
  type: CoherentRXBlock
  library: lattrex.official
  params:
    loop_bw: 0.05
    damping: 1.0
    kp: 3
    ki: 1
  placement:
    chip: 0
    cells:
    - {cell_id: phase, x: 0, y: 0, face: east}
    - {cell_id: sin_fold, x: 1, y: 0, face: east}
    - {cell_id: cos_fold, x: 2, y: 0, face: east}
    - {cell_id: table_sin, x: 3, y: 0, face: east}
    - {cell_id: table_cos, x: 4, y: 0, face: east}
    - {cell_id: rotate, x: 5, y: 0, face: east}
    - {cell_id: pd_pi, x: 6, y: 0, face: south}
    - {cell_id: yi_relay, x: 7, y: 0, face: south}
    - {cell_id: resampler, x: 7, y: 1, face: east}
    - {cell_id: ted, x: 8, y: 1, face: east}
    - {cell_id: loop_filter, x: 9, y: 1, face: east}
    - {cell_id: slicer, x: 9, y: 0, face: east}
    transit_cells:
    - {x: 6, y: 1, face: west}
    - {x: 5, y: 1, face: west}
    - {x: 4, y: 1, face: west}
    - {x: 3, y: 1, face: west}
    - {x: 2, y: 1, face: west}
    - {x: 1, y: 1, face: west}
    - {x: 0, y: 1, face: north}
connections:
- name: coherentrx_to_x16_out
  from: {block: coherentrx, port: out}
  to: {chip_port: {chip: 0, port: x16_out}}
