options:
  parameters:
    author: Lattrex
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: "PRODUCTION coherent BPSK RX demo with the RRC matched-filter front\
      \ end (GRC-first workflow). Built from the REAL DSP blocks so it IMPORTS into\
      \ placeKYT: ComplexRRCMatchedFilter -> ComplexCostasLoop -> GardnerTimingRecovery\
      \ -> BPSKSlicer get placed + bus-routed; source/sink -> chip ports. The SAME\
      \ flowgraph RUNS linked to the placeKYT-hosted chip: Simulation -> Run as GNURadio\
      \ Server in placeKYT, set server_port below to the printed port, then Execute\
      \ here. kyttar_source batches the whole I/Q burst through the hosted chip\
      \ in one RPC. The QT time sinks show the INPUT waveform (top) versus the RECOVERED\
      \ bits (bottom) \u2014 the input-vs-output view."
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: coherent_bpsk_rx_mf_demo
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: "Coherent BPSK RX (RRC matched filter) \u2014 input vs recovered bits"
    window_size: (1600,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: n_syms
  id: variable
  parameters:
    comment: BPSK symbols in the burst
    value: '160'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [200, 80]
    rotation: 0
    state: enabled
- name: server_port
  id: variable
  parameters:
    comment: placeKYT prints this on "Run as GNURadio Server"
    value: '58950'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [40, 160]
    rotation: 0
    state: enabled
- name: bit_sink
  id: qtgui_time_sink_x
  parameters:
    affinity: ''
    alias: ''
    alpha1: '1.0'
    alpha10: '1.0'
    alpha2: '1.0'
    alpha3: '1.0'
    alpha4: '1.0'
    alpha5: '1.0'
    alpha6: '1.0'
    alpha7: '1.0'
    alpha8: '1.0'
    alpha9: '1.0'
    autoscale: 'False'
    axislabels: 'True'
    color1: blue
    color10: dark blue
    color2: red
    color3: green
    color4: black
    color5: cyan
    color6: magenta
    color7: yellow
    color8: dark red
    color9: dark green
    comment: "recovered bits (chip out) \u2014 MF + Costas + Gardner RX"
    ctrlpanel: 'False'
    entags: 'True'
    grid: 'True'
    gui_hint: 1,0,1,1
    label1: recovered bit
    label10: Signal 10
    label2: Signal 2
    label3: Signal 3
    label4: Signal 4
    label5: Signal 5
    label6: Signal 6
    label7: Signal 7
    label8: Signal 8
    label9: Signal 9
    legend: 'True'
    marker1: '-1'
    marker10: '-1'
    marker2: '-1'
    marker3: '-1'
    marker4: '-1'
    marker5: '-1'
    marker6: '-1'
    marker7: '-1'
    marker8: '-1'
    marker9: '-1'
    name: '"Recovered bits (chip x16_out)"'
    nconnections: '1'
    size: '128'
    srate: '1'
    stemplot: 'False'
    style1: '1'
    style10: '1'
    style2: '1'
    style3: '1'
    style4: '1'
    style5: '1'
    style6: '1'
    style7: '1'
    style8: '1'
    style9: '1'
    tr_chan: '0'
    tr_delay: '0'
    tr_level: '0.0'
    tr_mode: qtgui.TRIG_MODE_FREE
    tr_slope: qtgui.TRIG_SLOPE_POS
    tr_tag: '""'
    type: float
    update_time: '0.10'
    width1: '1'
    width10: '1'
    width2: '1'
    width3: '1'
    width4: '1'
    width5: '1'
    width6: '1'
    width7: '1'
    width8: '1'
    width9: '1'
    ylabel: bit
    ymax: '1.3'
    ymin: '-0.3'
    yunit: '""'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1576, 200.0]
    rotation: 0
    state: enabled
- name: c2f
  id: blocks_complex_to_float
  parameters:
    affinity: ''
    alias: ''
    comment: split I (re) for the input-waveform view
    maxoutbuf: '0'
    minoutbuf: '0'
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [424, 80]
    rotation: 0
    state: enabled
- name: costas
  id: kyttar_costas_loop
  parameters:
    affinity: ''
    alias: ''
    comment: Complex Costas carrier recovery (placed on chip)
    damping: '1.0'
    device_id: '"kyttar_0"'
    loop_bw: '0.05'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [912, 152.0]
    rotation: 0
    state: enabled
- name: gardner
  id: kyttar_gardner_ted
  parameters:
    affinity: ''
    alias: ''
    comment: Gardner timing recovery (placed on chip)
    device_id: '"kyttar_0"'
    ki: '1'
    kp: '3'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1080, 288.0]
    rotation: 0
    state: enabled
- name: import_stim
  id: import
  parameters:
    alias: ''
    comment: RRC BPSK burst generator (carrier + timing offset)
    imports: from gnuradio.kyttar import coherent_demo_stim as stim
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [304, 24.0]
    rotation: 0
    state: enabled
- name: input_sink
  id: qtgui_time_sink_x
  parameters:
    affinity: ''
    alias: ''
    alpha1: '1.0'
    alpha10: '1.0'
    alpha2: '1.0'
    alpha3: '1.0'
    alpha4: '1.0'
    alpha5: '1.0'
    alpha6: '1.0'
    alpha7: '1.0'
    alpha8: '1.0'
    alpha9: '1.0'
    autoscale: 'False'
    axislabels: 'True'
    color1: blue
    color10: dark blue
    color2: red
    color3: green
    color4: black
    color5: cyan
    color6: magenta
    color7: yellow
    color8: dark red
    color9: dark green
    comment: input RRC BPSK waveform (in-phase, before the chip)
    ctrlpanel: 'False'
    entags: 'True'
    grid: 'True'
    gui_hint: 0,0,1,1
    label1: input I
    label10: Signal 10
    label2: Signal 2
    label3: Signal 3
    label4: Signal 4
    label5: Signal 5
    label6: Signal 6
    label7: Signal 7
    label8: Signal 8
    label9: Signal 9
    legend: 'True'
    marker1: '-1'
    marker10: '-1'
    marker2: '-1'
    marker3: '-1'
    marker4: '-1'
    marker5: '-1'
    marker6: '-1'
    marker7: '-1'
    marker8: '-1'
    marker9: '-1'
    name: '"Input waveform (RRC BPSK, in-phase)"'
    nconnections: '1'
    size: '256'
    srate: '1'
    stemplot: 'False'
    style1: '1'
    style10: '1'
    style2: '1'
    style3: '1'
    style4: '1'
    style5: '1'
    style6: '1'
    style7: '1'
    style8: '1'
    style9: '1'
    tr_chan: '0'
    tr_delay: '0'
    tr_level: '0.0'
    tr_mode: qtgui.TRIG_MODE_FREE
    tr_slope: qtgui.TRIG_SLOPE_POS
    tr_tag: '""'
    type: float
    update_time: '0.10'
    width1: '1'
    width10: '1'
    width2: '1'
    width3: '1'
    width4: '1'
    width5: '1'
    width6: '1'
    width7: '1'
    width8: '1'
    width9: '1'
    ylabel: amplitude
    ymax: '1.2'
    ymin: '-1.2'
    yunit: '""'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [648, 56]
    rotation: 0
    state: enabled
- name: mf
  id: kyttar_complex_rrc_matched_filter
  parameters:
    affinity: ''
    alias: ''
    alpha: '0.35'
    comment: RRC matched filter front end (placed on chip)
    device_id: '"kyttar_0"'
    maxoutbuf: '0'
    minoutbuf: '0'
    span: '8'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [688, 328.0]
    rotation: 0
    state: enabled
- name: msink
  id: kyttar_sink
  parameters:
    affinity: ''
    alias: ''
    comment: recovered bits <- placeKYT chip x16_out (batch)
    device_id: '"kyttar_0"'
    hold_secs: '8.0'
    maxoutbuf: '0'
    minoutbuf: '0'
    num_channels: '1'
    port_name: '"x16_out"'
    server_port: server_port
    server_repeat: 'False'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1312, 336.0]
    rotation: 0
    state: enabled
- name: msrc
  id: kyttar_source
  parameters:
    affinity: ''
    alias: ''
    burst_len: stim.burst_len(n_syms)
    comment: I/Q burst -> placeKYT chip x16_in (batch); fans to MF xi/xq
    complex_in: complex
    device_id: '"kyttar_0"'
    maxoutbuf: '0'
    minoutbuf: '0'
    num_channels: '1'
    port_name: '"x16_in"'
    server_host: '"127.0.0.1"'
    server_port: server_port
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [424, 220]
    rotation: 0
    state: enabled
- name: slicer
  id: kyttar_bpsk_slicer
  parameters:
    affinity: ''
    alias: ''
    comment: BPSK slicer (placed on chip)
    device_id: '"kyttar_0"'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1200, 136.0]
    rotation: 0
    state: enabled
- name: src
  id: blocks_vector_source_x
  parameters:
    affinity: ''
    alias: ''
    comment: "RRC BPSK burst (carrier + timing offset) into the chip \u2014 REPEAT\
      \ so the flowgraph never reaches EOF (which would tear down the graph before\
      \ the QT time sink ever paints); the Kyttar Source dispatches the batch ONCE\
      \ then passes through, and the Sink re-emits the recovered bits for a stable\
      \ live plot."
    maxoutbuf: '0'
    minoutbuf: '0'
    repeat: 'True'
    tags: '[]'
    type: complex
    vector: stim.burst(n_syms)
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [200, 232]
    rotation: 0
    state: enabled

connections:
- [c2f, '0', input_sink, '0']
- [costas, '0', gardner, '0']
- [gardner, '0', slicer, '0']
- [mf, '0', costas, '0']
- [mf, '1', costas, '1']
- [msink, '0', bit_sink, '0']
- [msrc, '0', mf, '0']
- [msrc, '0', mf, '1']
- [slicer, '0', msink, '0']
- [src, '0', c2f, '0']
- [src, '0', msrc, '0']

metadata:
  file_format: 1
  grc_version: 3.10.12.0
