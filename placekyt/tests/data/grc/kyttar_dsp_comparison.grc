options:
  parameters:
    author: Lattrex
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: Compare Kyttar DSP blocks with standard GNURadio blocks
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: kyttar_dsp_comparison
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Kyttar DSP Comparison
    window_size: (1280,1024)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: agc_rate
  id: variable
  parameters:
    comment: AGC adaptation rate
    value: '0.01'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [624, 12]
    rotation: 0
    state: enabled
- name: agc_target
  id: variable
  parameters:
    comment: AGC target level
    value: '0.7'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [520, 12]
    rotation: 0
    state: enabled
- name: dc_offset
  id: variable
  parameters:
    comment: DC offset added to signal
    value: '0.2'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [280, 12]
    rotation: 0
    state: enabled
- name: fir_taps
  id: variable
  parameters:
    comment: FIR filter taps (3-tap lowpass)
    value: '[0.25, 0.5, 0.25]'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [392, 12]
    rotation: 0
    state: enabled
- name: output_gain
  id: variable
  parameters:
    comment: Post-Kyttar gain boost
    value: '3.3'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [728, 12]
    rotation: 0
    state: enabled
- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: '32000'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [184, 12]
    rotation: 0
    state: enabled
- name: analog_sig_source_x_0
  id: analog_sig_source_x
  parameters:
    affinity: ''
    alias: ''
    amp: '0.3'
    comment: Sine wave + DC offset
    freq: '500'
    maxoutbuf: '0'
    minoutbuf: '0'
    offset: dc_offset
    phase: '0'
    samp_rate: samp_rate
    showports: 'False'
    type: float
    waveform: analog.GR_SIN_WAVE
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 200.0]
    rotation: 0
    state: true
- name: blocks_throttle_0
  id: blocks_throttle
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    ignoretag: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    samples_per_second: samp_rate
    type: float
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [200, 216.0]
    rotation: 0
    state: true
- name: dc_blocker_xx_0
  id: dc_blocker_xx
  parameters:
    affinity: ''
    alias: ''
    comment: Reference DC Blocker
    length: '32'
    long_form: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    type: ff
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [376, 320.0]
    rotation: 0
    state: true
- name: analog_agc2_xx_0
  id: analog_agc2_xx
  parameters:
    affinity: ''
    alias: ''
    attack_rate: agc_rate
    comment: Reference AGC
    decay_rate: agc_rate
    gain: '0.5'
    max_gain: '10'
    maxoutbuf: '0'
    minoutbuf: '0'
    reference: agc_target
    type: float
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [744, 296.0]
    rotation: 0
    state: true
- name: fir_filter_xxx_0
  id: fir_filter_xxx
  parameters:
    affinity: ''
    alias: ''
    comment: Reference FIR Filter
    decim: '1'
    maxoutbuf: '0'
    minoutbuf: '0'
    samp_delay: '0'
    taps: fir_taps
    type: fff
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [560, 312.0]
    rotation: 0
    state: true
- name: kyttar_dc_blocker_0
  id: kyttar_dc_blocker
  parameters:
    affinity: ''
    alias: ''
    comment: Kyttar DC Blocker
    device_id: '"kyttar_0"'
    length: '2'
    long_form: 'False'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [560, 128.0]
    rotation: 0
    state: true
- name: kyttar_device_0
  id: kyttar_device
  parameters:
    alias: ''
    chip_type: '"12x12_dev"'
    comment: Kyttar Device Configuration
    device_id: '"kyttar_0"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 420.0]
    rotation: 0
    state: true
- name: kyttar_fir_filter_0
  id: kyttar_fir_filter
  parameters:
    affinity: ''
    alias: ''
    coefficients: fir_taps
    comment: Kyttar FIR Filter
    device_id: '"kyttar_0"'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [744, 128.0]
    rotation: 0
    state: true
- name: kyttar_agc_0
  id: kyttar_agc
  parameters:
    affinity: ''
    alias: ''
    comment: Kyttar AGC
    device_id: '"kyttar_0"'
    initial_gain: '0.5'
    maxoutbuf: '0'
    minoutbuf: '0'
    rate: agc_rate
    target: agc_target
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [928, 112.0]
    rotation: 0
    state: true
- name: kyttar_sink_0
  id: kyttar_sink
  parameters:
    affinity: ''
    alias: ''
    comment: Exit from Kyttar chip
    device_id: '"kyttar_0"'
    maxoutbuf: '0'
    minoutbuf: '0'
    port_name: '"x16_out"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1112, 128.0]
    rotation: 0
    state: true
- name: blocks_multiply_const_0
  id: blocks_multiply_const_vxx
  parameters:
    affinity: ''
    alias: ''
    comment: Post-chip gain boost
    const: output_gain
    maxoutbuf: '0'
    minoutbuf: '0'
    type: float
    vlen: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1296, 128.0]
    rotation: 0
    state: true
- name: kyttar_source_0
  id: kyttar_source
  parameters:
    affinity: ''
    alias: ''
    comment: Entry into Kyttar chip
    device_id: '"kyttar_0"'
    maxoutbuf: '0'
    minoutbuf: '0'
    port_name: '"x16_in"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [376, 128.0]
    rotation: 0
    state: true
- name: qtgui_freq_sink_x_0
  id: qtgui_freq_sink_x
  parameters:
    affinity: ''
    alias: ''
    alpha1: '1.0'
    alpha10: '1.0'
    alpha2: '1.0'
    alpha3: '1.0'
    alpha4: '1.0'
    alpha5: '1.0'
    alpha6: '1.0'
    alpha7: '1.0'
    alpha8: '1.0'
    alpha9: '1.0'
    autoscale: 'False'
    average: '1.0'
    axislabels: 'True'
    bw: samp_rate
    color1: '"blue"'
    color10: '"dark blue"'
    color2: '"red"'
    color3: '"green"'
    color4: '"black"'
    color5: '"cyan"'
    color6: '"magenta"'
    color7: '"yellow"'
    color8: '"dark red"'
    color9: '"dark green"'
    comment: Frequency domain comparison
    ctrlpanel: 'False'
    fc: '0'
    fftsize: '1024'
    freqhalf: 'True'
    grid: 'True'
    gui_hint: 1,0,1,2
    label: Relative Gain
    label1: Input
    label10: ''
    label2: Kyttar
    label3: Reference
    label4: ''
    label5: ''
    label6: ''
    label7: ''
    label8: ''
    label9: ''
    legend: 'True'
    maxoutbuf: '0'
    minoutbuf: '0'
    name: '"Frequency Comparison"'
    nconnections: '3'
    norm_window: 'False'
    showports: 'False'
    tr_chan: '0'
    tr_level: '0.0'
    tr_mode: qtgui.TRIG_MODE_FREE
    tr_tag: '""'
    type: float
    units: dB
    update_time: '0.10'
    width1: '1'
    width10: '1'
    width2: '1'
    width3: '1'
    width4: '1'
    width5: '1'
    width6: '1'
    width7: '1'
    width8: '1'
    width9: '1'
    wintype: window.WIN_BLACKMAN_hARRIS
    ymax: '10'
    ymin: '-100'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1000, 616.0]
    rotation: 0
    state: true
- name: qtgui_time_sink_x_0
  id: qtgui_time_sink_x
  parameters:
    affinity: ''
    alias: ''
    alpha1: '1.0'
    alpha10: '1.0'
    alpha2: '1.0'
    alpha3: '1.0'
    alpha4: '1.0'
    alpha5: '1.0'
    alpha6: '1.0'
    alpha7: '1.0'
    alpha8: '1.0'
    alpha9: '1.0'
    autoscale: 'False'
    axislabels: 'True'
    color1: blue
    color10: dark blue
    color2: red
    color3: green
    color4: black
    color5: cyan
    color6: magenta
    color7: yellow
    color8: dark red
    color9: dark green
    comment: Compare Kyttar vs Reference outputs
    ctrlpanel: 'False'
    entags: 'True'
    grid: 'True'
    gui_hint: 0,0,1,2
    label1: Input (with DC)
    label10: Signal 10
    label2: Kyttar Output
    label3: Reference Output
    label4: Signal 4
    label5: Signal 5
    label6: Signal 6
    label7: Signal 7
    label8: Signal 8
    label9: Signal 9
    legend: 'True'
    marker1: '-1'
    marker10: '-1'
    marker2: '-1'
    marker3: '-1'
    marker4: '-1'
    marker5: '-1'
    marker6: '-1'
    marker7: '-1'
    marker8: '-1'
    marker9: '-1'
    name: '"DSP Comparison"'
    nconnections: '3'
    size: '2048'
    srate: samp_rate
    stemplot: 'False'
    style1: '1'
    style10: '1'
    style2: '1'
    style3: '1'
    style4: '1'
    style5: '1'
    style6: '1'
    style7: '1'
    style8: '1'
    style9: '1'
    tr_chan: '0'
    tr_delay: '0'
    tr_level: '0.0'
    tr_mode: qtgui.TRIG_MODE_FREE
    tr_slope: qtgui.TRIG_SLOPE_POS
    tr_tag: '""'
    type: float
    update_time: '0.10'
    width1: '1'
    width10: '1'
    width2: '2'
    width3: '2'
    width4: '1'
    width5: '1'
    width6: '1'
    width7: '1'
    width8: '1'
    width9: '1'
    ylabel: Amplitude
    ymax: '1'
    ymin: '-1'
    yunit: '""'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1000, 440.0]
    rotation: 0
    state: true

connections:
- [analog_sig_source_x_0, '0', blocks_throttle_0, '0']
- [blocks_throttle_0, '0', dc_blocker_xx_0, '0']
- [blocks_throttle_0, '0', kyttar_source_0, '0']
- [blocks_throttle_0, '0', qtgui_freq_sink_x_0, '0']
- [blocks_throttle_0, '0', qtgui_time_sink_x_0, '0']
- [dc_blocker_xx_0, '0', fir_filter_xxx_0, '0']
- [fir_filter_xxx_0, '0', analog_agc2_xx_0, '0']
- [analog_agc2_xx_0, '0', qtgui_freq_sink_x_0, '2']
- [analog_agc2_xx_0, '0', qtgui_time_sink_x_0, '2']
- [kyttar_dc_blocker_0, '0', kyttar_fir_filter_0, '0']
- [kyttar_fir_filter_0, '0', kyttar_agc_0, '0']
- [kyttar_agc_0, '0', kyttar_sink_0, '0']
- [kyttar_sink_0, '0', blocks_multiply_const_0, '0']
- [blocks_multiply_const_0, '0', qtgui_freq_sink_x_0, '1']
- [blocks_multiply_const_0, '0', qtgui_time_sink_x_0, '1']
- [kyttar_source_0, '0', kyttar_dc_blocker_0, '0']

metadata:
  file_format: 1
  grc_version: 3.10.12.0
